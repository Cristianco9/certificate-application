# Application environment
NODE_ENV=development

# Database dialect (used by Sequelize)
DIALECT=mysql

# Port where the Express app will run
APP_PORT=3377

# --- Database credentials ---
# Single application user (root is NOT used by the app, only for container initialization)
DB_USER=developer
DB_PASSWORD=aa24d32b8b1cfe04a74f668fd58acddbccbe86a9a17a0eff52bb5830e3d1d652

# Root password, used only to initialize the MySQL container (creates DB_USER, grants privileges, etc.)
DB_ROOT_PASSWORD=d47ac305ae7593831b5fea899e6037907161a5c29d1ed4710a0219ba229f9a95

# Database name
DB_NAME=iensc_certification_application_db

# --- Connection host/port ---
# Use these values when connecting FROM YOUR MACHINE (app running outside Docker)
# 127.0.0.1 + mapped port (3355)
DB_HOST=127.0.0.1
DB_PORT=3355

# --- App secrets ---
API_KEY=48fdd9794d35198c4867fb0180252908cc742b18835545d4342ae9544748aa0d
AUTH_APP_JWT_SECRET_KEY=b863794517c66b712790c8e8f84038c5ea575c767d8c9444965ea4845ed1e1e5
